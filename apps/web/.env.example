# ============================================================================
# Guerrilla RS - Variables de Entorno
# USO 2: Sistema Social Core
# 
# INSTRUCCIONES:
# 1. Copiar este archivo a .env: cp .env.example .env
# 2. Generar valores seguros para secrets (ver comentarios)
# 3. NUNCA commitear el archivo .env real
# ============================================================================

# =============================================================================
# BASE DE DATOS (PostgreSQL)
# =============================================================================

# URL de conexión a PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://guerrilla:changeme_in_production@localhost:5432/guerrillars?schema=public"

# Variables individuales (usadas por docker-compose)
POSTGRES_USER="guerrilla"
POSTGRES_PASSWORD="changeme_in_production"  # Generar con: openssl rand -base64 32
POSTGRES_DB="guerrillars"

# =============================================================================
# REDIS (KeyDB)
# =============================================================================

# URL de conexión a Redis
REDIS_URL="redis://:changeme_in_production@localhost:6379"

# Password de Redis
REDIS_PASSWORD="changeme_in_production"  # Generar con: openssl rand -base64 32

# =============================================================================
# MINIO (Almacenamiento S3-compatible)
# =============================================================================

# Endpoint de MinIO (sin http/https)
MINIO_ENDPOINT="localhost:9000"

# Credenciales de acceso
MINIO_ACCESS_KEY="minioadmin"           # Cambiar en producción
MINIO_SECRET_KEY="changeme_in_production"  # Generar con: openssl rand -base64 32

# Buckets
MINIO_BUCKET_MEDIA="guerrillars-media"
MINIO_BUCKET_AVATARS="guerrillars-avatars"
MINIO_USE_SSL="false"  # "true" en producción con SSL

# =============================================================================
# JWT (JSON Web Tokens)
# =============================================================================

# Clave privada ES256 para firmar JWT
# Generar con: openssl ecparam -genkey -name prime256v1 -noout -out private.pem
# Contenido del archivo private.pem (incluir -----BEGIN... y -----END...)
JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
MHcCAQEE...tu_clave_privada_aqui...Qo=
-----END EC PRIVATE KEY-----"

# Clave pública ES256 para verificar JWT
# Generar con: openssl ec -in private.pem -pubout -out public.pem
# Contenido del archivo public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE...tu_clave_publica_aqui...==
-----END PUBLIC KEY-----"

# =============================================================================
# SEGURIDAD DE SESIÓN
# =============================================================================

# Salt para hashing de IPs y datos sensibles en logs
# Generar con: openssl rand -hex 32
SESSION_SALT="generate_random_salt_here_64_chars_hexadecimal"

# Clave efímera para encriptación temporal de imágenes de verificación
# Generar con: openssl rand -hex 32
EPHEMERAL_KEY="generate_random_key_here_64_chars_hexadecimal"

# =============================================================================
# FACE API (Reconocimiento Facial)
# =============================================================================

# Ruta a los modelos de face-api.js
# Los modelos deben descargarse de: https://github.com/justadudewhohacks/face-api.js-models
FACE_API_MODELS_PATH="./models"

# =============================================================================
# MEILISEARCH (Motor de Búsqueda)
# =============================================================================

# Host de Meilisearch
MEILI_HOST="http://localhost:7700"

# API Key de Meilisearch (Master Key)
# Generar con: openssl rand -base64 32
MEILI_API_KEY="changeme_in_production"

# =============================================================================
# ENTORNO
# =============================================================================

# Modo de ejecución: development | production
NODE_ENV="development"

# Puerto de la aplicación
PORT="3000"

# URL pública de la aplicación (usada para generar URLs)
PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# RATE LIMITING
# =============================================================================

# Máximo de requests por minuto por IP
RATE_LIMIT_IP="60"

# Máximo de requests por minuto por usuario autenticado
RATE_LIMIT_USER="100"

# =============================================================================
# LOGGING
# =============================================================================

# Nivel de log: debug | info | warn | error
LOG_LEVEL="info"

# Anonimizar IPs en logs (recomendado: true)
LOG_ANONIMIZE_IP="true"

# =============================================================================
# VERIFICACIÓN DE EDAD
# =============================================================================

# Umbral de coincidencia facial (0.0 - 1.0, menor = más estricto)
FACE_MATCH_THRESHOLD="0.6"

# Confianza mínima de OCR para aceptar documento (0-100)
OCR_MIN_CONFIDENCE="50"

# Máximo de intentos de verificación por hora por IP
VERIFICATION_MAX_ATTEMPTS="3"

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================

# 1. GENERACIÓN DE SECRETS:
#    - SESSION_SALT: openssl rand -hex 32
#    - EPHEMERAL_KEY: openssl rand -hex 32
#    - POSTGRES_PASSWORD: openssl rand -base64 32
#    - REDIS_PASSWORD: openssl rand -base64 32
#    - MINIO_SECRET_KEY: openssl rand -base64 32
#    - MEILI_API_KEY: openssl rand -base64 32
#
# 2. GENERACIÓN DE CLAVES JWT:
#    - Private: openssl ecparam -genkey -name prime256v1 -noout -out private.pem
#    - Public: openssl ec -in private.pem -pubout -out public.pem
#    - Copiar contenido de los archivos a las variables
#
# 3. DESCARGA DE MODELOS FACE-API:
#    wget https://github.com/justadudewhohacks/face-api.js-models/raw/master/models.tar.gz
#    tar xzf models.tar.gz -C ./models/
#
# 4. EN PRODUCCIÓN:
#    - Usar HTTPS obligatoriamente
#    - Configurar backups automáticos
#    - Monitorear logs de auditoría
#    - Rotar secrets periódicamente
